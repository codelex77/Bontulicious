<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bontulicious Hair & Beauty</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a96e;
    --gold-light: #e8d5b0;
    --dark: #0d0d0d;
    --dark-2: #141414;
    --dark-3: #1c1c1c;
    --dark-4: #242424;
    --text: #f0ece4;
    --muted: #888;
    --accent: #c9a96e;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* HERO */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    background: var(--dark-2);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201,169,110,0.08) 0%, transparent 70%),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 60px,
        rgba(201,169,110,0.015) 60px,
        rgba(201,169,110,0.015) 61px
      );
  }

  .hero-tag {
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: fadeUp 1s ease forwards;
    opacity: 0;
  }

  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    animation: fadeUp 1s 0.2s ease forwards;
    opacity: 0;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
    max-width: 400px;
    line-height: 2;
    animation: fadeUp 1s 0.4s ease forwards;
    opacity: 0;
  }

  .hero-line {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    margin: 2.5rem auto 0;
    animation: fadeUp 1s 0.6s ease forwards;
    opacity: 0;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.5rem 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(13,13,13,0.9), transparent);
    backdrop-filter: blur(4px);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    color: var(--gold);
    font-weight: 400;
  }

  .nav-wa {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: 1px solid rgba(201,169,110,0.3);
    padding: 0.6rem 1.2rem;
    transition: all 0.3s ease;
  }

  .nav-wa:hover {
    background: var(--gold);
    color: var(--dark);
    border-color: var(--gold);
  }

  /* FILTER BAR */
  .filter-section {
    padding: 3rem 2rem 2rem;
    text-align: center;
    border-bottom: 1px solid rgba(201,169,110,0.1);
  }

  .filter-label {
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .filter-btn {
    background: none;
    border: 1px solid rgba(201,169,110,0.2);
    color: var(--muted);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .filter-btn:hover, .filter-btn.active {
    background: var(--gold);
    color: var(--dark);
    border-color: var(--gold);
  }

  /* CATALOGUE */
  .catalogue-header {
    padding: 3rem 2.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .catalogue-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .product-count {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: rgba(201,169,110,0.08);
    margin: 0 2.5rem 4rem;
  }

  .product-card {
    background: var(--dark-2);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .product-card:hover { background: var(--dark-3); }

  .product-img-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--dark-3);
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    filter: brightness(0.92) contrast(1.05);
  }

  .product-card:hover .product-img-wrap img {
    transform: scale(1.04);
  }

  /* Placeholder for products without real images */
  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--dark-4);
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: rgba(201,169,110,0.2);
    font-style: italic;
  }

  .product-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--gold);
    color: var(--dark);
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    font-weight: 600;
  }

  .product-info {
    padding: 1.2rem 1.4rem 1.4rem;
    border-top: 1px solid rgba(201,169,110,0.08);
  }

  .product-category {
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .product-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }

  .product-price {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--gold-light);
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(201,169,110,0.08);
  }

  .order-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid rgba(201,169,110,0.3);
    color: var(--text);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .order-btn:hover {
    background: var(--gold);
    color: var(--dark);
    border-color: var(--gold);
  }

  /* FOOTER */
  footer {
    background: var(--dark-2);
    border-top: 1px solid rgba(201,169,110,0.1);
    padding: 3rem 2.5rem;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--gold);
    font-style: italic;
    margin-bottom: 0.8rem;
  }

  .footer-tagline {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .footer-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: white;
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    font-family: 'Montserrat', sans-serif;
    transition: opacity 0.3s ease;
  }

  .footer-wa:hover { opacity: 0.85; }

  .footer-note {
    margin-top: 2rem;
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    backdrop-filter: blur(6px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--dark-2);
    border: 1px solid rgba(201,169,110,0.15);
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    animation: modalIn 0.3s ease;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.96) translateY(16px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    filter: brightness(0.92) contrast(1.05);
  }

  .modal-img-placeholder {
    width: 100%;
    aspect-ratio: 3/2;
    background: var(--dark-4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    color: rgba(201,169,110,0.15);
    font-style: italic;
  }

  .modal-body {
    padding: 2rem;
  }

  .modal-category {
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .modal-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .modal-price {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gold-light);
    margin-bottom: 1.2rem;
  }

  .modal-desc {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.9;
    letter-spacing: 0.03em;
    margin-bottom: 2rem;
  }

  .modal-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .btn-order {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: #25D366;
    color: white;
    text-decoration: none;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.9rem 1.5rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.25s ease;
  }

  .btn-order:hover { opacity: 0.85; }

  .btn-close {
    background: none;
    border: 1px solid rgba(201,169,110,0.2);
    color: var(--muted);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.9rem 1.5rem;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .btn-close:hover {
    border-color: var(--gold);
    color: var(--text);
  }

  @media (max-width: 600px) {
    .grid { margin: 0 0 4rem; gap: 1px; }
    .grid { grid-template-columns: repeat(2, 1fr); }
    .catalogue-header { padding: 2rem 1rem 1rem; }
    .catalogue-title { font-size: 1.8rem; }
    nav { padding: 1.2rem 1.2rem; }
    .hero h1 { font-size: 3rem; }
    .filter-section { padding: 2rem 1rem 1.5rem; }
    footer { padding: 2rem 1rem; }
  }
</style>
</head>
