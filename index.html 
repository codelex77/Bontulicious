const grid = document.getElementById('productGrid');
const countEl = document.getElementById('count');

function renderProducts(filtered) {
  grid.innerHTML = '';
  countEl.textContent = `${filtered.length} piece${filtered.length !== 1 ? 's' : ''}`;
  filtered.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'product-card';
    card.style.animationDelay = `${i * 0.04}s`;
    card.innerHTML = `
      <div class="product-img-wrap">
        <div class="img-placeholder">${p.emoji}</div>
      </div>
      <div class="product-info">
        <p class="product-category">${p.category}</p>
        <h3 class="product-name">${p.name}</h3>
        <p class="product-price">${p.price}</p>
        <div class="product-footer">
          <a class="order-btn" href="https://wa.me/${WA_NUMBER}?text=Hi%2C%20I'm%20interested%20in%20the%20${encodeURIComponent(p.name)}%20(${encodeURIComponent(p.price)})" target="_blank">
            Order →
          </a>
        </div>
      </div>
    `;
    card.querySelector('.product-img-wrap').addEventListener('click', () => openModal(p));
    card.querySelector('.product-name').addEventListener('click', () => openModal(p));
    grid.appendChild(card);
  });
}

function filterProducts(tag, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const filtered = tag === 'all' ? products : products.filter(p => p.tags.includes(tag));
  renderProducts(filtered);
}

function openModal(p) {
  document.getElementById('modalImg').innerHTML = `<div class="modal-img-placeholder">${p.emoji}</div>`;
  document.getElementById('modalCat').textContent = p.category;
  document.getElementById('modalName').textContent = p.name;
  document.getElementById('modalPrice').textContent = p.price;
  document.getElementById('modalDesc').textContent = p.desc;
  document.getElementById('modalWA').href = `https://wa.me/${WA_NUMBER}?text=Hi%2C%20I'm%20interested%20in%20the%20${encodeURIComponent(p.name)}%20(${encodeURIComponent(p.price)})`;
  document.getElementById('modal').classList.add('open');
}

function closeModal(e) {
  if (e.target.id === 'modal') document.getElementById('modal').classList.remove('open');
}

renderProducts(products);
</script>
